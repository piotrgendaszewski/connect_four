@{
    ViewData["Title"] = "Connect Four - Gra";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #333;
        padding: 20px;
        min-height: 100vh;
    }

    .game-container {
        max-width: 1000px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 250px;
        gap: 20px;
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    #game {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    h1 {
        color: #667eea;
        margin-bottom: 20px;
        text-align: center;
    }

    #board {
        display: grid;
        grid-template-columns: repeat(7, 70px);
        gap: 8px;
        margin-bottom: 20px;
        background: #1a1a2e;
        padding: 10px;
        border-radius: 8px;
    }

    .cell {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: #2d2d4e;
        cursor: pointer;
        transition: all 0.3s;
        border: 2px solid transparent;
    }

    .cell:hover {
        transform: scale(1.05);
    }

    .cell.player1 {
        background: #f7c948;
        box-shadow: 0 0 10px rgba(247, 201, 72, 0.5);
    }

    .cell.player2 {
        background: #e63946;
        box-shadow: 0 0 10px rgba(230, 57, 70, 0.5);
    }

    .cell.winning {
        animation: pulse 0.6s infinite;
        border: 2px solid gold;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    @@keyframes dropPiece {
        0% { transform: translateY(-500px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }

    .cell.dropping {
        animation: dropPiece 0.3s ease-in;
    }

    .column {
        display: flex;
        flex-direction: column;
    }

    .column:hover .cell:not(.player1):not(.player2) {
        background: #3d3d5e;
    }

    #status-message {
        background: #f0f0f0;
        padding: 12px 20px;
        border-radius: 6px;
        text-align: center;
        margin-bottom: 20px;
        font-weight: bold;
        color: #667eea;
        min-height: 40px;
    }

    .sidebar {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid #667eea;
    }

    .player-info {
        margin-bottom: 20px;
        padding: 12px;
        border-radius: 6px;
    }

    .player1-info {
        background: rgba(247, 201, 72, 0.2);
        border-left: 4px solid #f7c948;
    }

    .player2-info {
        background: rgba(230, 57, 70, 0.2);
        border-left: 4px solid #e63946;
    }

    .player-info h3 {
        font-size: 14px;
        margin-bottom: 8px;
        color: #333;
    }

    .player-color-info {
        margin-bottom: 15px;
        background: #e8f0ff;
        border-left: 4px solid #667eea;
        border-radius: 6px;
        padding: 10px 12px;
        font-weight: bold;
        color: #2d3e7f;
    }

    .player-color-dot {
        display: inline-block;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        vertical-align: middle;
        margin: 0 6px;
        border: 1px solid rgba(0, 0, 0, 0.15);
    }

    .player-color-dot.player1 {
        background: #f7c948;
        box-shadow: 0 0 6px rgba(247, 201, 72, 0.5);
    }

    .player-color-dot.player2 {
        background: #e63946;
        box-shadow: 0 0 6px rgba(230, 57, 70, 0.5);
    }

    .player-nick {
        font-weight: bold;
        font-size: 16px;
        word-break: break-all;
    }

    .ready-button {
        width: 100%;
        padding: 10px;
        background: #28a745;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        margin-bottom: 15px;
        transition: background 0.3s;
    }

    .ready-button:hover {
        background: #218838;
    }

    .ready-button:disabled {
        background: #ccc;
        cursor: not-allowed;
    }

    .countdown {
        background: #fff3cd;
        padding: 10px;
        border-radius: 6px;
        text-align: center;
        color: #856404;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .back-button {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 20px;
        background: #667eea;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
        transition: background 0.3s;
    }

    .back-button:hover {
        background: #764ba2;
    }

    #game-over-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        display: none;
    }

    #game-over-overlay.show {
        display: flex;
    }

    .game-over-content {
        background: white;
        padding: 40px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.3);
        max-width: 400px;
    }

    .game-over-content h2 {
        color: #667eea;
        font-size: 28px;
        margin-bottom: 15px;
    }

    .game-over-content p {
        font-size: 16px;
        color: #666;
        margin-bottom: 20px;
    }

    .game-over-button {
        display: inline-block;
        padding: 12px 30px;
        background: #667eea;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
        border: none;
        transition: background 0.3s;
    }

    .game-over-button:hover {
        background: #764ba2;
    }

    .game-over-button.rematch {
        background: #28a745;
        margin-right: 10px;
    }

    .game-over-button.rematch:hover {
        background: #218838;
    }

    @@media (max-width: 768px) {
        .game-container {
            grid-template-columns: 1fr;
        }

        #board {
            grid-template-columns: repeat(7, 50px);
        }

        .cell {
            width: 50px;
            height: 50px;
        }

        .sidebar {
            border-left: none;
            border-top: 4px solid #667eea;
        }
    }

    @@media (max-width: 480px) {
        #board {
            grid-template-columns: repeat(7, 40px);
        }

        .cell {
            width: 40px;
            height: 40px;
        }

        #board {
            gap: 4px;
        }
    }
</style>

<div id="game-container" 
     data-room-id="@ViewBag.RoomId" 
     data-nick="@ViewBag.Nick" 
     data-player-number="@ViewBag.PlayerNumber">

    <div class="game-container">
        <div id="game">
            <h1>? Connect Four</h1>
            <div id="status-message">Oczekiwanie na drugiego gracza...</div>
            <div id="board"></div>
            <a href="/" class="back-button">? Powrót do lobby</a>
        </div>

        <div class="sidebar">
            <button class="ready-button" id="readyButton" onclick="signalReady()" style="display: none;">
    Gotowy!
            </button>

            <div class="player-color-info" id="playerColorInfo"></div>

            <div class="countdown" id="countdown" style="display: none;">
                Czekamy: <span id="countdownValue">60</span>s
            </div>

            <div class="player-info player1-info">
                <h3>?? Gracz 1</h3>
                <div class="player-nick" id="player1Nick">Czekanie...</div>
            </div>

            <div class="player-info player2-info">
                <h3>?? Gracz 2</h3>
                <div class="player-nick" id="player2Nick">Czekanie...</div>
            </div>
        </div>
    </div>
</div>

<div id="game-over-overlay">
    <div class="game-over-content">
        <h2 id="gameOverTitle">Gra skończona!</h2>
        <p id="gameOverMessage"></p>
        <button class="game-over-button rematch" id="rematchButton" onclick="requestRematch()">Rewanż</button>
        <button class="game-over-button" onclick="location.href='/'">Powrót do lobby</button>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script src="/js/game.js"></script>
