namespace ConnectFour.Controllers;

using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using ConnectFour.Data;
using ConnectFour.Models;
using ConnectFour.Services;

public class HomeController : Controller
{
    private readonly ILogger<HomeController> _logger;
    private readonly RoomManager _roomManager;
    private readonly AppDbContext _db;
    private readonly BackgroundTaskService _backgroundTaskService;

    public HomeController(ILogger<HomeController> logger, RoomManager roomManager, 
        AppDbContext db, BackgroundTaskService backgroundTaskService)
    {
        _logger = logger;
        _roomManager = roomManager;
        _db = db;
        _backgroundTaskService = backgroundTaskService;
    }

    public IActionResult Index()
    {
        _logger.LogInformation("Home/Index accessed");
        return View();
    }

    public IActionResult Ranking()
    {
        _logger.LogInformation("Home/Ranking accessed");
        return View();
    }

    public IActionResult History()
    {
        _logger.LogInformation("Home/History accessed");
        return View();
    }

    [HttpGet("api/rooms")]
    public IActionResult GetRooms()
    {
        try
        {
            var rooms = _roomManager.GetAllRooms()
                .Where(r => r.Status == RoomStatus.Waiting || r.Status == RoomStatus.Ready)
                .Select(r => new
                {
                    roomId = r.RoomId.ToString(),
                    player1Nick = r.Player1Nick,
                    player2Nick = r.Player2Nick,
                    status = r.Status.ToString(),
                    createdAt = r.CreatedAt
                })
                .ToList();

            _logger.LogInformation("Returning {Count} rooms", rooms.Count);
            return Ok(rooms);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting rooms");
            return StatusCode(500, new { error = "Błąd pobierania pokoi" });
        }
    }

    [HttpGet("api/ranking")]
    public async Task<IActionResult> GetRanking()
    {
        try
        {
            var ranking = _backgroundTaskService.GetCachedRanking();

            if (ranking == null)
            {
                ranking = await _db.Players
                    .OrderByDescending(p => p.Wins)
                    .Take(10)
                    .ToListAsync();
            }

            var result = ranking.Select((p, index) => new
            {
                place = index + 1,
                nick = p.Nick,
                wins = p.Wins,
                losses = p.Losses,
                draws = p.Draws,
                winPercentage = p.Wins + p.Losses + p.Draws > 0 
                    ? Math.Round((double)p.Wins / (p.Wins + p.Losses + p.Draws) * 100, 2) 
                    : 0
            }).ToList();

            _logger.LogInformation("Returning ranking with {Count} players", result.Count);
            return Ok(result);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting ranking");
            return StatusCode(500, new { error = "Błąd pobierania rankingu" });
        }
    }

    [HttpGet("api/history")]
    public async Task<IActionResult> GetHistory()
    {
        try
        {
            var history = await _db.GameRecords
                .OrderByDescending(g => g.PlayedAt)
                .Take(20)
                .Select(g => new
                {
                    date = g.PlayedAt,
                    player1Nick = g.Player1Nick,
                    player2Nick = g.Player2Nick,
                    winnerNick = g.WinnerNick,
                    durationSeconds = g.DurationSeconds
                })
                .ToListAsync();

            _logger.LogInformation("Returning history with {Count} records", history.Count);
            return Ok(history);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting history");
            return StatusCode(500, new { error = "Błąd pobierania historii" });
        }
    }
}
